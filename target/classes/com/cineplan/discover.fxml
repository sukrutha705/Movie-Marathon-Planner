<?xml version="1.0" encoding="UTF-8"?>
 
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
 
<VBox spacing="20.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cineplan.controller.DiscoverController">
   <children>
      <VBox spacing="5.0">
         <children>
            <Label styleClass="heading-1" text="Discover &amp; Import Movies" />
            <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 13px;" text="Search the entire IMDb database in real-time to import any movie in the world into your local library." />
         </children>
      </VBox>
 
      <HBox spacing="15.0" alignment="CENTER_LEFT">
         <children>
            <TextField fx:id="txtSearchQuery" prefHeight="40.0" prefWidth="400.0" promptText="Search globally by movie title (e.g. Avatar, Titanic)..." styleClass="text-field" />
            <Button mnemonicParsing="false" onAction="#handleSearch" prefHeight="40.0" styleClass="button, button-primary" text="Search Global Database" />
            <Label fx:id="lblStatus" style="-fx-text-fill: #888888; -fx-font-size: 13px; -fx-padding: 0 0 0 10px;" text="Enter a title to search." />
         </children>
      </HBox>
 
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
         <content>
            <FlowPane fx:id="flowResults" hgap="20.0" vgap="20.0" style="-fx-background-color: transparent;" />
         </content>
      </ScrollPane>
   </children>
</VBox>
