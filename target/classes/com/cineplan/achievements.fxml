<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cineplan.controller.AchievementsController">
   <children>
      <VBox spacing="5.0">
         <children>
            <Label styleClass="heading-1" text="Marathon Achievements" />
            <Label styleClass="label-secondary" text="Earn badges by configuring epic plans and exploring different movie genres!" />
         </children>
      </VBox>
      
      <!-- List of Achievements -->
      <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="containerAchievements" spacing="15.0" style="-fx-padding: 10px;" />
         </content>
      </ScrollPane>
   </children>
</VBox>
