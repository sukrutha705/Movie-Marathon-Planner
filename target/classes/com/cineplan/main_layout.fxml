<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1050.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cineplan.controller.MainController">
   <left>
      <VBox prefWidth="210.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="app-title" text="CINEPLAN" />
            <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowDashboard" styleClass="nav-button, nav-button-active" text="Marathon Planner" />
            <Button fx:id="btnMovieManager" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowMovieManager" styleClass="nav-button" text="Manage Movies" />
            <Button fx:id="btnDiscover" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowDiscover" styleClass="nav-button" text="Discover (IMDb)" />
            <Button fx:id="btnSavedMarathons" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowSavedMarathons" styleClass="nav-button" text="Saved Marathons" />
            <Button fx:id="btnQuiz" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowQuiz" styleClass="nav-button" text="Personality Quiz" />
            <Button fx:id="btnAchievements" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowAchievements" styleClass="nav-button" text="Achievements" />
            <Button fx:id="btnAnalytics" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowAnalytics" styleClass="nav-button" text="Analytics" />
         </children>
      </VBox>
   </left>
   <center>
      <BorderPane fx:id="contentPane" prefHeight="200.0" prefWidth="200.0" style="-fx-padding: 30px;" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
